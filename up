<title>Portfolio E5 — Faycel NAMOUNE — BTS SIO SISR</title>
<style>
:root{
  --navy:#0B1F3A;--blue:#1A4A8A;--orange:#D4690A;--o2:#F59E0B;
  --white:#fff;--bg:#F8FAFC;--card:#fff;
  --gray:#64748B;--lgray:#F1F5F9;--border:#E2E8F0;
  --green:#166534;--red:#991B1B;
  --r:10px;--sh:0 2px 16px rgba(11,31,58,.09);
}
*,::before,::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--navy);line-height:1.65}
nav{position:sticky;top:0;z-index:99;background:var(--navy);border-bottom:3px solid var(--orange)}
.nav-wrap{max-width:1100px;margin:auto;padding:0 24px;display:flex;align-items:center;gap:4px;overflow-x:auto}
.nav-brand{color:var(--o2);font-weight:700;font-size:.9rem;padding:14px 0;margin-right:auto;white-space:nowrap}
.nav-wrap a{color:rgba(255,255,255,.7);font-size:.8rem;font-weight:600;text-decoration:none;padding:14px 13px;white-space:nowrap;border-bottom:3px solid transparent;transition:all .2s}
.nav-wrap a:hover,.nav-wrap a.active{color:#fff;border-bottom-color:var(--orange)}
.hero{background:linear-gradient(135deg,var(--navy) 0%,#1A4A8A 100%);color:#fff;position:relative;overflow:hidden}
.hero::after{content:'';position:absolute;bottom:-1px;left:0;right:0;height:48px;background:var(--bg);clip-path:ellipse(55% 100% at 50% 100%)}
.hero-inner{max-width:1100px;margin:auto;padding:56px 32px 72px}
.hero-pill{display:inline-block;background:var(--orange);color:#fff;font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:5px 14px;border-radius:20px;margin-bottom:18px}
.hero h1{font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;line-height:1.15;margin-bottom:10px}
.hero h1 em{color:var(--o2);font-style:normal}
.hero-sub{opacity:.8;font-size:1rem;margin-bottom:28px;max-width:520px}
.hero-tags{display:flex;flex-wrap:wrap;gap:10px}
.hero-tag{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:20px;padding:5px 14px;font-size:.82rem}
.wrap{max-width:1100px;margin:auto;padding:52px 24px 80px}
section{margin-bottom:60px;scroll-margin-top:65px}
.sec-title{display:flex;align-items:center;gap:14px;margin-bottom:22px}
.sec-title h2{font-size:1.25rem;font-weight:800;color:var(--navy);white-space:nowrap}
.sec-title .ico{font-size:1.2rem}
.sec-line{flex:1;height:2px;background:linear-gradient(90deg,var(--orange) 0%,transparent 100%)}
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--sh);overflow:hidden}
.info-table{width:100%;border-collapse:collapse}
.info-table td{padding:9px 14px;border-bottom:1px solid var(--border);font-size:.9rem}
.info-table td:first-child{font-weight:700;color:var(--blue);background:var(--lgray);width:180px;text-align:right;font-size:.88rem}
.info-table tr:last-child td{border-bottom:none}
.swot{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:14px}
.swot-box{border-radius:8px;padding:14px 16px}
.swot-box h4{font-size:.9rem;font-weight:700;margin-bottom:8px}
.swot-box li{font-size:.85rem;line-height:1.55;padding:1px 0;list-style:none}
.sw-f{background:#E8F5E9}.sw-f h4{color:var(--green)}
.sw-w{background:#FFEBEE}.sw-w h4{color:var(--red)}
.sw-o{background:#E3F2FD}.sw-o h4{color:var(--blue)}
.sw-t{background:#FFF8E1}.sw-t h4{color:var(--orange)}
.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px}
.skill-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:16px 18px;box-shadow:var(--sh)}
.skill-card h4{font-size:.88rem;font-weight:700;color:var(--navy);margin-bottom:10px}
.prog{background:var(--lgray);border-radius:20px;height:7px;overflow:hidden}
.prog-fill{height:100%;border-radius:20px;background:linear-gradient(90deg,var(--orange),var(--o2))}
.prog-label{font-size:.75rem;color:var(--gray);margin-top:4px}
.timeline{position:relative;padding-left:22px}
.timeline::before{content:'';position:absolute;left:5px;top:0;bottom:0;width:2px;background:var(--border)}
.tl-item{position:relative;margin-bottom:18px}
.tl-item::before{content:'';position:absolute;left:-19px;top:5px;width:10px;height:10px;border-radius:50%;background:var(--orange);border:2px solid var(--white);box-shadow:0 0 0 2px var(--orange)}
.tl-item h4{font-weight:700;font-size:.92rem;margin-bottom:2px}
.tl-date{font-size:.76rem;color:var(--orange);font-weight:700;margin-bottom:3px}
.tl-item p{font-size:.87rem;color:var(--gray)}
.sp-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:24px}
.sp-card{display:flex;flex-direction:column;transition:transform .2s,box-shadow .2s;border-radius:var(--r);overflow:hidden;box-shadow:var(--sh)}
.sp-card:hover{transform:translateY(-4px);box-shadow:0 10px 32px rgba(11,31,58,.14)}
.sp-head{background:var(--navy);color:#fff;padding:22px 26px 18px;border-top:4px solid var(--orange)}
.sp-num{font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;opacity:.6;margin-bottom:4px;font-weight:700}
.sp-head h3{font-size:1.05rem;font-weight:700;line-height:1.35;margin-bottom:14px}
.sp-tags{display:flex;flex-wrap:wrap;gap:7px}
.sp-tag{background:rgba(255,255,255,.13);border-radius:14px;padding:3px 11px;font-size:.77rem}
.sp-body{padding:20px 26px;flex:1;display:flex;flex-direction:column;background:var(--card)}
.sp-desc{font-size:.9rem;color:var(--gray);margin-bottom:14px;line-height:1.65}
.sp-list{list-style:none;flex:1;margin-bottom:18px}
.sp-list li{font-size:.86rem;color:var(--gray);padding:5px 0;border-bottom:1px solid var(--lgray);display:flex;align-items:flex-start;gap:8px}
.sp-list li:last-child{border-bottom:none}
.sp-list li::before{content:'✓';color:var(--green);font-weight:700;flex-shrink:0;margin-top:1px}
.btn-pdf{display:flex;align-items:center;justify-content:center;gap:8px;background:var(--orange);color:#fff;font-weight:700;font-size:.88rem;text-decoration:none;padding:12px 22px;border-radius:8px;transition:background .2s,transform .15s}
.btn-pdf:hover{background:#B85A08;transform:scale(1.02)}
.veille-intro{background:var(--navy);border-radius:var(--r);padding:24px 28px;color:#fff;border-left:5px solid var(--orange);margin-bottom:20px}
.veille-intro h3{font-size:1rem;font-weight:700;margin-bottom:8px}
.veille-intro p{font-size:.9rem;opacity:.82;line-height:1.65}
.methodes{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;margin-bottom:24px}
.meth{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:12px 14px;text-align:center}
.meth .ico{font-size:1.5rem;margin-bottom:5px}
.meth p{font-size:.8rem;color:var(--gray);font-weight:600}
.veille-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:16px}
.veille-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:20px;box-shadow:var(--sh);border-top:3px solid var(--orange);transition:transform .2s}
.veille-card:hover{transform:translateY(-3px)}
.v-tag{display:inline-block;font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;padding:2px 9px;border-radius:4px;margin-bottom:9px}
.t-secu{background:#FFEBEE;color:var(--red)}.t-net{background:#FFF8E1;color:#92400E}
.t-cloud{background:#E3F2FD;color:#1565C0}.t-ia{background:#E8F5E9;color:var(--green)}.t-reg{background:#F3E8FF;color:#6B21A8}
.veille-card h3{font-size:.95rem;font-weight:700;color:var(--navy);margin-bottom:9px;line-height:1.35}
.veille-card p{font-size:.86rem;color:var(--gray);line-height:1.6}
.v-source{margin-top:11px;font-size:.76rem;color:var(--orange);font-weight:600}
.v-date{font-size:.72rem;color:var(--gray);margin-top:3px}
.proj-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px}
.proj-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:20px;box-shadow:var(--sh)}
.proj-card h3{font-size:.92rem;font-weight:700;color:var(--navy);margin-bottom:6px}
.proj-card p{font-size:.86rem;color:var(--gray);margin-bottom:12px;line-height:1.6}
.tags{display:flex;flex-wrap:wrap;gap:6px}
.tag{background:var(--lgray);border:1px solid var(--border);border-radius:14px;padding:2px 10px;font-size:.75rem;font-weight:600;color:var(--blue)}
.synth-wrap{overflow-x:auto}
.synth-table{width:100%;border-collapse:collapse;background:var(--card);border-radius:var(--r);overflow:hidden;box-shadow:var(--sh)}
.synth-table th{background:var(--navy);color:#fff;font-size:.87rem;padding:12px 14px;text-align:left}
.synth-table td{padding:10px 14px;border-bottom:1px solid var(--border);font-size:.87rem}
.synth-table tr:nth-child(even) td{background:var(--lgray)}
.synth-table tr:last-child td{border-bottom:none}
.ok{color:var(--green);font-weight:700}.partial{color:var(--orange);font-weight:600}
.conclu{background:var(--navy);color:#fff;border-radius:var(--r);padding:32px 36px;border-top:4px solid var(--orange)}
.conclu h3{font-size:1.1rem;font-weight:700;margin-bottom:12px;color:var(--o2)}
.conclu p{opacity:.87;line-height:1.75;font-size:.96rem;margin-bottom:12px}
.conclu p:last-child{margin-bottom:0}
.conclu strong{color:var(--o2)}
footer{text-align:center;padding:24px;font-size:.82rem;color:var(--gray);border-top:1px solid var(--border)}
@media(max-width:640px){.hero-inner{padding:40px 18px 60px}.wrap{padding:36px 16px 60px}.swot{grid-template-columns:1fr}.conclu{padding:22px 20px}.info-table td:first-child{width:120px}}
</style>
